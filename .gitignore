# ==========================================================
# Engineering Standards Pack (ESP) v1.0
# Git Ignore
# ==========================================================

# ------------------------------
# Operating System
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------
# Python
# ------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ------------------------------
# Environment
# ------------------------------
.env
.env.local
.env.production

# Keep the template
!.env.example

# ------------------------------
# IDE
# ------------------------------
.vscode/
.idea/
*.iml

# ------------------------------
# Logs
# ------------------------------
*.log
logs/

# ------------------------------
# Docker
# ------------------------------
docker-data/
docker-volumes/

# ------------------------------
# Build
# ------------------------------
dist/
build/
out/

# ------------------------------
# Temporary
# ------------------------------
*.tmp
*.bak
*.swp