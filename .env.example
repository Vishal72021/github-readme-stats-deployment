###############################################################################
# GitHub Readme Stats Deployment
#
# Copy this file to ".env" before running the deployment.
###############################################################################

###############################################################################
# GitHub Personal Access Token
#
# Required.
#
# Generate a GitHub Personal Access Token with the permissions recommended by
# GitHub Readme Stats.
###############################################################################

PAT_1=

###############################################################################
# Application
###############################################################################

PORT=9000

###############################################################################
# Cache
#
# Cache duration in seconds.
###############################################################################

CACHE_SECONDS=21600

###############################################################################
# Environment
#
# Allowed values:
#   development
#   production
###############################################################################

ENVIRONMENT=development

###############################################################################
# Logging
#
# Allowed values:
#   DEBUG
#   INFO
#   WARNING
#   ERROR
###############################################################################

LOG_LEVEL=INFO